  "globalFailureModes": [
    {
      "failureId": "hand_weapon_separation",
      "meaning": "A held weapon or prop no longer touches the intended hand grip anchor."
    },
    {
      "failureId": "floating_shield_or_book",
      "meaning": "An offhand prop appears beside the hand instead of being held or supported by it."
    },
    {
      "failureId": "foot_baseline_drift",
      "meaning": "A generated frame moves one or both feet away from the locked standing baseline."
    },
    {
      "failureId": "head_scale_drift",
      "meaning": "Face, hair, helmet, or body generation changes the locked head scale or placement."
    },
    {
      "failureId": "source_pixel_anchor_mismatch",
      "meaning": "The pixelized sprite no longer projects the approved source anchors by normalized coordinates."
    }
  ],
  "rules": [
    "Review generated source sprites before pixel outputs.",
    "If a review suite fails, regenerate or adjust the pose/anchor contract before importing the sprite.",
    "Do not loosen runtime anchors to match a bad generated image.",
    "Use reference images for visual target intent only; do not copy their background, labels, or side-by-side layout."
  ]
