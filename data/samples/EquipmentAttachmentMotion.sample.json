  "motionContracts": [
    {
      "motionId": "idle_loop_v1",
      "frameCount": 3,
      "requiredFrameFields": ["frameId", "durationMs", "poseTemplateId", "anchorOverrides", "layerOverrides", "eventTags"],
      "rules": [
        "Feet stay locked unless a future walk/run template is explicitly used.",
        "Chest and shoulders may move by small breathing offsets.",
        "Equipment follows anchor transforms, not independent CSS-only motion."
      ]
    },
    {
      "motionId": "basic_attack_v1",
      "frameCount": 3,
      "requiredFrameIds": ["attack_ready", "attack_hit", "attack_recover"],
      "rules": [
        "The attack_hit frame owns the damage_window event tag.",
        "Weapon tip and hitbox are evaluated from item anchors after frame transforms.",
        "VFX spawns from motion event tags, not from the body sprite image."
      ]
    },
    {
      "motionId": "wand_book_cast_v1",
      "frameCount": 3,
      "requiredFrameIds": ["attack_ready", "attack_hit", "attack_recover"],
      "rules": [
        "The attack_hit frame owns the damage_window event tag.",
        "Wand and grimoire attachments follow Cast_Hand, Wand_Tip, Book_Grip, and Book_Center anchors.",
        "This runtime contract is covered by the equipment attachment plan before final wand/book class sprites are generated."
      ]
    },
    {
      "motionId": "hit_reaction_v1",
      "frameCount": 2,
      "requiredFrameIds": ["hit_back", "hit_return"],
      "rules": [
        "The actor root may move backward, but equipment remains attached to body anchors.",
        "Do not swap equipment layers during hit reaction unless the item metadata declares a pose override."
      ]
    }
  ],
  "firstImplementationOrder": [
    "Lock base body v2 idle anchors.",
    "Attach helmet, torso armor, one-hand weapon, and shield on idle_default.",
    "Add gauntlet handwear using wrist and forearm anchors.",
    "Add boots using knee and foot baseline anchors.",
    "Add cloak/back proxies using Neck_Base, Chest_Center, and Hip_Center anchors.",
    "Add pose templates for great weapon, bow, staff, and fist guard.",
    "Add wand/book caster runtime anchors before final wand/book source sprites are generated.",
    "Add idle_loop_v1 frame transforms.",
    "Add basic_attack_v1 frame transforms and event tags.",
    "Only then generate new weapon/class test images from the anchor contract."
  ]
}
