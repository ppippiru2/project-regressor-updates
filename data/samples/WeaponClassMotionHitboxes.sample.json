      "frames": ["attack_ready", "attack_hit", "attack_recover"],
      "damageWindowFrame": "attack_hit",
      "eventTags": ["damage_window", "vfx_spawn.basic_slash", "sfx.weapon_swing"],
      "hitbox": {
        "type": "capsule",
        "fromAnchor": "Hand_ScreenLeft_Grip",
        "toAnchor": "Elbow_ScreenLeft",
        "radius": 42,
        "originAnchor": "Hand_ScreenLeft_Grip",
        "notes": "Proxy one-hand slash until weapon tip anchors are exposed for the final sword-shield source pose."
      }
    },
    {
