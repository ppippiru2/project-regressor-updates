{
  "schemaVersion": 1,
  "updatedAt": "2026-06-30",
  "status": "draft_sample",
  "purpose": "Defines draft attack motion and hitbox anchor contracts for weapon/class pose templates before generated class test sprites are approved.",
  "rules": [
    "Hitboxes are derived from explicit pose anchors, not from finished image bounding boxes.",
    "Each attack motion must have attack_ready, attack_hit, and attack_recover frames.",
    "The attack_hit frame must own damage_window and at least one hitbox or projectile/effect spawn anchor.",
    "Standing attack templates keep foot baselines locked unless a later movement template explicitly allows foot motion.",
    "These hitboxes are visual QA contracts for sprite production, not final combat balance numbers."
  ],
  "motions": [
